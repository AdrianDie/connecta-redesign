connecta.no\/wp-content\/uploads\/2024\/04\/speech-bubble.png?resize=350%2C200&ssl=1","width":350,"height":200},"classes":[]},{"id":1665,"url":"https:\/\/connecta.no\/kontakt\/","url_meta":{"origin":4955,"position":3},"title":"Kontakt","author":"Adrian","date":"24. september 2022","format":false,"excerpt":"\u00c5pningstiderMandag: 09-19Tirsdag: 09-17Onsdag: 09-19Torsdag: 09-19Fredag: 09-17L\u00f8rdag - S\u00f8ndag: stengt\u00a0E-post: kjersti@connecta.no amalie@connecta.noTelefon: 922 50 863 Kontakt Connecta tilbyr terapeutiske samtaler online. Vi har lang erfaring som terapeut og veileder i offentlig og privat sektor, og bist\u00e5r gjerne med terapi for enkeltpersoner, familier, par og bedrifter.\u00a0\u00a0\u00a0Hos oss kan du f\u00e5 hjelp til\u2026","rel":"","context":"Liknende innlegg","block_context":{"text":"Liknende innlegg","link":""},"img":{"alt_text":"","src":"","width":0,"height":0},"classes":[]},{"id":4960,"url":"https:\/\/connecta.no\/amalie-hylland\/","url_meta":{"origin":4955,"position":4},"title":"Amalie Hylland","author":"Adrian","date":"25. april 2024","format":false,"excerpt":"Amalie Hylland Amalie er utdannet og autorisert psykolog i Spania, og tilbyr online terapi til norske klienter. Hun har en omfattende erfaring som klinisk psykolog.\u00a0Hun har arbeidet med et bredt utvalg av psykiske helseutfordringer som angst, fobier, grubling, depresjon, sosiale vansker og ferdigheter, grensesetting, selvhevdelse, utbrenthet, selvtillit, selvbilde, prokrastinering, selvskading,\u2026","rel":"","context":"Liknende innlegg","block_context":{"text":"Liknende innlegg","link":""},"img":{"alt_text":"","src":"https:\/\/i0.wp.com\/connecta.no\/wp-content\/uploads\/2024\/03\/Bilde-Amalie-768x1024.png?resize=350%2C200&ssl=1","width":350,"height":200,"srcset":"https:\/\/i0.wp.com\/connecta.no\/wp-content\/uploads\/2024\/03\/Bilde-Amalie-768x1024.png?resize=350%2C200&ssl=1 1x, https:\/\/i0.wp.com\/connecta.no\/wp-content\/uploads\/2024\/03\/Bilde-Amalie-768x1024.png?resize=525%2C300&ssl=1 1.5x, https:\/\/i0.wp.com\/connecta.no\/wp-content\/uploads\/2024\/03\/Bilde-Amalie-768x1024.png?resize=700%2C400&ssl=1 2x"},"classes":[]},{"id":4376,"url":"https:\/\/connecta.no\/behandlingsmetode\/","url_meta":{"origin":4955,"position":5},"title":"Behandlingsmetode","author":"Adrian","date":"7. april 2024","format":false,"excerpt":"Behandlingsmetode Vi tilbyr kognitiv atferdsterapi, en retning innenfor psykoterapi som har vist seg \u00e5\u00a0v\u00e6re effektiv ved en rekke psykiske helseutfordringer\u00a0som bla. angst,\u00a0depresjon, lavt selvbilde, panikklidelser, fobier, s\u00f8vnvansker,\u00a0stressmestring, sinneproblemer og avhengighetsproblemer.Om du er preget av negative\u00a0tanker, vonde og vanskelige f\u00f8lelser og\/eller har en u\u00f8nsket v\u00e6rem\u00e5te,\u00a0s\u00e5 kan det bli vanskelig \u00e5 mestre\u00a0hverdagen.\u00a0\u00c5\u2026","rel":"","context":"Liknende innlegg","block_context":{"text":"Liknende innlegg","link":""},"img":{"alt_text":"","src":"https:\/\/connecta.no\/wp-content\/uploads\/2024\/04\/Behandlingsmetode.svg","width":350,"height":200,"srcset":"https:\/\/connecta.no\/wp-content\/uploads\/2024\/04\/Behandlingsmetode.svg 1x, https:\/\/connecta.no\/wp-content\/uploads\/2024\/04\/Behandlingsmetode.svg 1.5x, https:\/\/connecta.no\/wp-content\/uploads\/2024\/04\/Behandlingsmetode.svg 2x"},"classes":[]}],"_links":{"self":[{"href":"https:\/\/connecta.no\/wp-json\/wp\/v2\/pages\/4955","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/connecta.no\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/connecta.no\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"https:\/\/connecta.no\/wp-json\/wp\/v2\/users\/223811887"}],"replies":[{"embeddable":true,"href":"https:\/\/connecta.no\/wp-json\/wp\/v2\/comments?post=4955"}],"version-history":[{"count":22,"href":"https:\/\/connecta.no\/wp-json\/wp\/v2\/pages\/4955\/revisions"}],"predecessor-version":[{"id":6315,"href":"https:\